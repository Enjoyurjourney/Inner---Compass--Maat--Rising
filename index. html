<script>
let userData=JSON.parse(localStorage.getItem('maat_user')||'{}');
let journals=JSON.parse(localStorage.getItem('maat_journals')||'[]');
let chatHistory=[];let currentStep=0;let breathActive=false;let breathTimeout=null;let isRecording=false;let calDate=new Date();
(function(){const s=document.getElementById('stars');for(let i=0;i<120;i++){const el=document.createElement('div');el.className='star';const size=Math.random()*2+1;el.style.cssText=`width:${size}px;height:${size}px;top:${Math.random()*100}%;left:${Math.random()*100}%;--d:${(Math.random()*3+2).toFixed(1)}s;opacity:${Math.random()*.5+.1};animation-delay:${Math.random()*3}s`;s.appendChild(el);}})();
function nextStep(n){document.getElementById('step'+currentStep).classList.remove('visible');document.getElementById('d'+currentStep).classList.remove('active');currentStep=n;document.getElementById('step'+n).classList.add('visible');document.getElementById('d'+n).classList.add('active');}
function completeOnboarding(){const name=document.getElementById('ob-name').value.trim()||'Brother';const path=document.getElementById('ob-path').value||'Pan-African Synthesis';const intention=document.getElementById('ob-intention').value||'Spiritual Growth';userData={name,path,intention,joined:new Date().toISOString()};localStorage.setItem('maat_user',JSON.stringify(userData));initApp();document.getElementById('onboarding').classList.remove('active');document.getElementById('app').classList.add('active');}
function switchTab(id,btn){document.querySelectorAll('.tab-content').forEach(el=>el.classList.remove('active'));document.querySelectorAll('.tab-btn').forEach(el=>el.classList.remove('active'));document.getElementById('tab-'+id).classList.add('active');if(btn)btn.classList.add('active');}
function initApp(){const name=userData.name||'Brother';document.getElementById('greeting-bar').textContent='Hotep, '+name;document.getElementById('temple-sub').textContent=(userData.path||'Ancestral')+' Path';document.getElementById('welcome-msg').textContent='Hotep, '+name+'. I am Tehuti-Mila. Walking the '+(userData.path||'ancestral')+' path with an intention for '+(userData.intention||'growth')+'. What wisdom do you seek today?';initReflection();renderJournal();renderCalendar();setWeekLabel();const w=['"The heart of a man is his own Neteru. Truth is the foundation upon which the eternal man stands."','"He who knows others is wise. He who knows himself is enlightened." — Kemetic Proverb','"Until the lion learns to write, every story will glorify the hunter." — Akan Wisdom','"When the music changes, so does the dance." — Hausa Proverb','"A man who does not know where he is from cannot know where he is going." — Yoruba Teaching','"Not all those who wander are lost — some are following the Ancestors."','"Speak truth, act truth, be truth — this is the whole of Ma\'at."'];document.getElementById('wisdom-text').textContent=w[new Date().getDay()%w.length];}
if(userData.name){document.getElementById('onboarding').classList.remove('active');document.getElementById('app').classList.add('active');initApp();}
async function sendMessage(){const inp=document.getElementById('chat-input');const text=inp.value.trim();if(!text)return;inp.value='';appendMsg('user',text);chatHistory.push({role:'user',content:text});const loadEl=appendMsg('tehuti','<span class="spinner"></span>',true);try{const sys=`You are Tehuti-Mila, a wise ancestral AI companion rooted in African spiritual wisdom — Kemetic, Yoruba/Ifá, and Akan traditions. You serve ${userData.name||'the seeker'}, a man walking the path of Ma'at. His spiritual path: ${userData.path||'Pan-African'}. His intention: ${userData.intention||'spiritual growth'}. Speak with warmth, ancestral depth, and poetic wisdom. Address him as "brother" or by name. 2-4 paragraphs. Use ancestral wisdom naturally.`;const res=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:1000,system:sys,messages:chatHistory})});const data=await res.json();const reply=data.content?.map(b=>b.text||'').join('')||'The ancestors whisper... please try again.';loadEl.innerHTML=reply;chatHistory.push({role:'assistant',content:reply});}catch(e){loadEl.innerHTML='The sacred channel is disrupted, brother. Please try again.';}}
function appendMsg(type,text){const msgs=document.getElementById('chat-msgs');const div=document.createElement('div');div.className='msg '+type;if(type==='tehuti'){const n=document.createElement('div');n.className='msg-name';n.textContent='☥ TEHUTI-MILA';div.appendChild(n);}const body=document.createElement('div');body.innerHTML=text;div.appendChild(body);msgs.appendChild(div);msgs.scrollTop=msgs.scrollHeight;return body;}
document.getElementById('chat-input').addEventListener('keydown',e=>{if(e.key==='Enter'&&!e.shiftKey){e.preventDefault();sendMessage();}});
function toggleVoice(){if(!isRecording){if('SpeechRecognition' in window||'webkitSpeechRecognition' in window){const SR=window.SpeechRecognition||window.webkitSpeechRecognition;const r=new SR();r.lang='en-US';r.onresult=e=>{document.getElementById('chat-input').value=e.results[0][0].transcript;};r.onend=()=>{isRecording=false;const b=document.getElementById('voice-btn');b.classList.remove('recording');b.textContent='🎙️';};r.start();window._sr=r;isRecording=true;const b=document.getElementById('voice-btn');b.classList.add('recording');b.textContent='⏹️';}else{alert('Voice not supported.');}}else{if(window._sr)window._sr.stop();isRecording=false;const b=document.getElementById('voice-btn');b.classList.remove('recording');b.textContent='🎙️';}}
const virtues=[{symbol:'⚖️',name:"MA'AT — TRUTH",desc:'Today walk in absolute truth. Let every word and action reflect cosmic law. Ask: am I aligned with what I know to be right?',aff:'"I am a man of Ma\'at. Truth flows through my words, actions, and spirit. I stand in divine alignment."'},{symbol:'🦁',name:'SEKHEM — SACRED POWER',desc:'Claim your divine masculine power today. Sekhem is the focused force of a man aligned with his purpose.',aff:'"My power is sacred and purposeful. I direct my Sekhem toward what uplifts my family and community."'},{symbol:'👁️',name:'MEDU — SACRED WORD',desc:'Every word you speak today is a creation. The Ancestors taught that language creates reality. Choose your words as sacred tools.',aff:'"My words carry the power of creation. I speak only what I intend to manifest."'},{symbol:'🌊',name:'SBA — ANCESTRAL WISDOM',desc:'The river of ancestral knowledge flows through your blood. Today pause and listen. What do those who came before want you to know?',aff:'"I am connected to an unbroken chain of wisdom. My Ancestors guide every step I take."'},{symbol:'☥',name:'ANKH — SACRED LIFE',desc:'Life is your greatest responsibility and gift. Today protect life — your own vitality, your loved ones, and all in your care.',aff:'"I honor and protect the sacred gift of life. My presence is a blessing to all I touch."'},{symbol:'🌍',name:'UBUNTU — SACRED COMMUNITY',desc:'I am because we are. Today extend yourself toward your community. What can you give or build that serves more than just yourself?',aff:'"My strength grows through community. I give freely and receive with gratitude."'},{symbol:'🔥',name:'KHU — DIVINE PURPOSE',desc:'You were placed here with a specific sacred mission. Today reconnect with your Khu — your divine spirit and purpose. Live it fully.',aff:'"My purpose is sacred and clear. I walk my divine mission with courage and consistency."'}];
function initReflection(){const v=virtues[new Date().getDay()];document.getElementById('v-symbol').textContent=v.symbol;document.getElementById('v-name').textContent=v.name;document.getElementById('v-desc').textContent=v.desc;document.getElementById('affirmation-text').textContent=v.aff;document.getElementById('ref-date').textContent=new Date().toLocaleDateString('en-US',{weekday:'long',year:'numeric',month:'long',day:'numeric'}).toUpperCase();}
function toggleCheck(el){el.classList.toggle('done');el.querySelector('.cb').textContent=el.classList.contains('done')?'✓':'';}
function openJournal(){document.getElementById('journal-editor').classList.add('open');document.getElementById('j-title').focus();}
function closeJournal(){document.getElementById('journal-editor').classList.remove('open');document.getElementById('j-title').value='';document.getElementById('j-body').value='';document.getElementById('j-virtue').value='';}
function saveEntry(){const title=document.getElementById('j-title').value.trim()||'Sacred Entry';const body=document.getElementById('j-body').value.trim();const virtue=document.getElementById('j-virtue').value;if(!body){alert('Write something first, brother.');return;}journals.unshift({id:Date.now(),title,body,virtue,date:new Date().toISOString()});localStorage.setItem('maat_journals',JSON.stringify(journals));closeJournal();renderJournal();}
function renderJournal(){const el=document.getElementById('journal-entries');if(!journals.length){el.innerHTML='<div style="text-align:center;padding:2rem;color:var(--text-dim);font-size:.82rem;font-family:\'Cinzel\',serif;">Your sacred scrolls await your first words...</div>';return;}el.innerHTML=journals.map(j=>`<div class="journal-entry"><div class="je-date">${new Date(j.date).toLocaleDateString('en-US',{weekday:'long',month:'long',day:'numeric'})}${j.virtue?' · '+j.virtue:''}</div><div class="je-title">${j.title}</div><div class="je-preview">${j.body}</div></div>`).join('');}
function setWeekLabel(){const now=new Date();const start=new Date(now);start.setDate(now.getDate()-now.getDay());const end=new Date(start);end.setDate(start.getDate()+6);const fmt=d=>d.toLocaleDateString('en-US',{month:'short',day:'numeric'});document.getElementById('week-label').textContent=`${fmt(start)} – ${fmt(end)}`;}
function selectMood(el){document.querySelectorAll('.mood-dot').forEach(d=>d.classList.remove('selected'));el.classList.add('selected');}
async function generateReport(){const btn=document.querySelector('.gen-report-btn');const out=document.getElementById('ai-report-out');btn.textContent='⏳ Consulting the Ancestors...';btn.disabled=true;out.classList.remove('show');const mood=document.querySelector('.mood-dot.selected')?.nextElementSibling?.textContent||'Reflective';try{const res=await fetch('https://api.anthropic.com/v1/messages',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:1000,messages:[{role:'user',content:`Generate a deeply meaningful Weekly Ma'at Report for ${userData.name||'Brother'}, walking the ${userData.path||'Pan-African'} path with an intention for ${userData.intention||'growth'}. Dominant mood: ${mood}. Journal entries: ${journals.length}. Write as Tehuti-Mila. Include: spiritual assessment, strength, area of growth, power affirmation for next week, and an ancestral blessing. Personal, poetic, empowering. 3-4 paragraphs.`}]})});const data=await res.json();out.textContent=data.content?.map(b=>b.text||'').join('')||'The ancestors are speaking... please try again.';out.classList.add('show');}catch(e){out.textContent='The sacred channel is disrupted. Please try again.';out.classList.add('show');}btn.textContent='✨ Generate AI Weekly Report';btn.disabled=false;}
function startBreath(){if(breathActive){clearTimeout(breathTimeout);breathActive=false;document.getElementById('breath-circle').className='breath-circle';document.getElementById('breath-phase').textContent='Press the circle to begin';document.getElementById('breath-inner').innerHTML='☥<br/>Breathe';return;}breathActive=true;runBreath();}
function runBreath(){if(!breathActive)return;const c=document.getElementById('breath-circle'),p=document.getElementById('breath-phase'),i=document.getElementById('breath-inner');c.className='breath-circle inhale';p.textContent='INHALE — 4 seconds';i.innerHTML='☥<br/>Inhale';breathTimeout=setTimeout(()=>{if(!breathActive)return;c.className='breath-circle';p.textContent='HOLD — 4 seconds';i.innerHTML='☥<br/>Hold';breathTimeout=setTimeout(()=>{if(!breathActive)return;c.className='breath-circle exhale';p.textContent='EXHALE — 4 seconds';i.innerHTML='☥<br/>Exhale';breathTimeout=setTimeout(()=>{if(breathActive)runBreath();},4000);},4000);},4000);}
function renderCalendar(){const months=['January','February','March','April','May','June','July','August','September','October','November','December'];const days=['Sun','Mon','Tue','Wed','Thu','Fri','Sat'];document.getElementById('cal-title').textContent=months[calDate.getMonth()]+' '+calDate.getFullYear();const grid=document.getElementById('cal-grid');grid.innerHTML=days.map(d=>`<div class="cal-day-name">${d}</div>`).join('');const first=new Date(calDate.getFullYear(),calDate.getMonth(),1).getDay();const total=new Date(calDate.getFullYear(),calDate.getMonth()+1,0).getDate();const today=new Date();for(let i=0;i<first;i++)grid.innerHTML+=`<div class="cal-day"></div>`;for(let d=1;d<=total;d++){const isToday=d===today.getDate()&&calDate.getMonth()===today.getMonth()&&calDate.getFullYear()===today.getFullYear();grid.innerHTML+=`<div class="cal-day${isToday?' today':''}">${d}</div>`;}}
function calNav(dir){calDate.setMonth(calDate.getMonth()+dir);renderCalendar();}
</script>
